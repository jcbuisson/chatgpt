<!DOCTYPE html>
<html lang="en">
<head>
   <meta charset="UTF-8">
   <meta name="viewport" content="width=device-width, initial-scale=1.0">
   <title>ChatGPT API</title>
   <link rel="stylesheet" href="/index.css">
</head>
<body>
   <h1>API de ChatGPT</h1>
   <h2>Extraction de données d'un PDF</h2>
   <div id="dropzone" class="dropzone">
      <p>glissez-déposez ici ou cliquez pour déposer un fichier PDF d’analyse de sang...</p>
      <input type="file" id="fileInput" name="file" accept="application/pdf" hidden>
   </div>
   <div id="message"></div>
</body>
</html>

<script>
   const dropzone = document.getElementById('dropzone')
   const fileInput = document.getElementById('fileInput')
   const message = document.getElementById('message')

   // Handle drag & drop
   dropzone.addEventListener('dragover', (e) => {
      e.preventDefault()
      dropzone.classList.add('hover')
   })

   dropzone.addEventListener('dragleave', () => {
      dropzone.classList.remove('hover')
   })

   dropzone.addEventListener('drop', (e) => {
      e.preventDefault()
      dropzone.classList.remove('hover')
      const file = e.dataTransfer.files[0]
      if (file) {
         uploadFile(file)
      }
   })

   // Handle click
   dropzone.addEventListener('click', () => fileInput.click())

   fileInput.addEventListener('change', (e) => {
      const file = e.target.files[0]
      if (file) {
         uploadFile(file)
      }
   })

   // Upload file to server
   async function uploadFile(file) {
      try {
         const formData = new FormData()
         formData.append('file', file)

         const response = await fetch('/upload', {
            method: 'POST',
            body: formData,
         })
         const json = await response.text()
         message.textContent = json
         const data = JSON.parse(json)
         res.render('results', data)
      } catch (error) {
         message.textContent = `Error: ${error.message}`
      }
   }
</script>
